DATABASE_URL=mysql+pymysql://<db_user>:<db_password>@<db_host>:3306/mahesh_meds
API_PORT=8000
DEBUG=false
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
CORS_ORIGINS=https://your-frontend-domain.example
# JWT_SECRET must be at least 32 characters. Generate one with:
# python -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET=

# Local development overrides:
# DEBUG=true
# COOKIE_SECURE=false
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Phone on same Wi-Fi (frontend Vite proxy — recommended):
#   DEBUG=true  → CORS allows http://192.168.x.x:8080 automatically
#   uvicorn app.main:app --reload --host 127.0.0.1 --port 8000
#   Frontend: npm run dev → npm run lan:url → open that URL on the phone
#
# Phone calling API directly (no proxy):
#   uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
#   CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://192.168.29.43:8080

# SMS service
SMS_ENABLED=false
SMS_PEID=
SMS_API_KEY=replace-with-provider-api-key
SMS_USERNAME=replace-with-provider-username
SMS_SENDER=MHSFND
SMS_BASE_URL=http://www.bulksmsapps.com/api/apismsv2.aspx
SMS_TIMEOUT_SECONDS=10

# Enable live sending only after PEID is confirmed and DLT template IDs
# are populated in the sms_templates table.
