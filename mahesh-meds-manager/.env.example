# Dev on phone over Wi‑Fi: leave VITE_API_URL unset (see README). Vite proxies /auth, /me, /api → backend.
# VITE_API_URL=
#
# Production same-origin deploy: leave VITE_API_URL unset when the frontend and API
# are served behind the same domain/reverse proxy.
#
# Or point directly at the API machine (requires uvicorn --host 0.0.0.0 and CORS_ORIGINS with your LAN URL):
# VITE_API_URL=http://192.168.1.10:8000
#
# Optional: pin center-admin UI to a center UUID from GET /api/v1/centers
# VITE_CENTER_ID=
